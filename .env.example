# --- CRM API ---
PORT=3000
# Chave exigida no header x-api-key de todas as rotas (exceto webhook)
CRM_API_KEY=troque-esta-chave

# --- Banco (Supabase Postgres) ---
# Supabase > Project Settings > Database > Connection string (URI, modo session ou transaction+pgbouncer)
DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
# Conexao direta (porta 5432 sem pooler) usada pelo prisma migrate
DIRECT_URL="postgresql://postgres.<ref>:<senha>@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# --- Evolution API ---
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=troque-esta-chave-evolution
# URL publica desta API que a Evolution chamara nos webhooks (use ngrok/tunnel em dev)
WEBHOOK_BASE_URL=http://host.docker.internal:3000
# Token que valida chamadas de webhook recebidas
WEBHOOK_TOKEN=troque-este-token

# --- Redis (filas de campanha) ---
REDIS_HOST=localhost
REDIS_PORT=6379
