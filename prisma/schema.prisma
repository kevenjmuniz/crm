generator client {
  provider      = "prisma-client-js"
  // native: dev local (Windows); linux-musl-openssl-3.0.x: runtime Alpine do Docker
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Equipe / atendimento ----------

enum UserRole {
  ADMIN
  SUPERVISOR
  AGENT
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  role          UserRole       @default(AGENT)
  active        Boolean        @default(true)
  queues        QueueUser[]
  conversations Conversation[] @relation("AssignedConversations")
  notes         Note[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// Fila/setor de atendimento (ex.: Vendas, Suporte)
model Queue {
  id            String         @id @default(uuid())
  name          String         @unique
  description   String?
  users         QueueUser[]
  conversations Conversation[]
  createdAt     DateTime       @default(now())
}

model QueueUser {
  queueId String
  userId  String
  queue   Queue  @relation(fields: [queueId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([queueId, userId])
}

// ---------- WhatsApp / Evolution ----------

enum InstanceStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
}

model Instance {
  id            String         @id @default(uuid())
  // nome usado na Evolution API (instanceName)
  name          String         @unique
  phone         String?
  status        InstanceStatus @default(DISCONNECTED)
  conversations Conversation[]
  campaigns     Campaign[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ---------- Contatos ----------

model Contact {
  id                 String              @id @default(uuid())
  // numero no formato E.164 sem sufixo @s.whatsapp.net (ex.: 5511999999999)
  phone              String              @unique
  name               String?
  pushName           String?
  avatarUrl          String?
  email              String?
  tags               ContactTag[]
  notes              Note[]
  conversations      Conversation[]
  deals              Deal[]
  campaignRecipients CampaignRecipient[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Tag {
  id       String       @id @default(uuid())
  name     String       @unique
  color    String?
  contacts ContactTag[]
}

model ContactTag {
  contactId String
  tagId     String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model Note {
  id        String   @id @default(uuid())
  content   String
  contactId String
  authorId  String?
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

// ---------- Conversas / mensagens ----------

enum ConversationStatus {
  PENDING // aguardando atendimento
  OPEN // em atendimento
  CLOSED
}

model Conversation {
  id            String             @id @default(uuid())
  contactId     String
  instanceId    String
  status        ConversationStatus @default(PENDING)
  assignedToId  String?
  queueId       String?
  unreadCount   Int                @default(0)
  lastMessageAt DateTime?
  contact       Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  instance      Instance           @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  assignedTo    User?              @relation("AssignedConversations", fields: [assignedToId], references: [id], onDelete: SetNull)
  queue         Queue?             @relation(fields: [queueId], references: [id], onDelete: SetNull)
  messages      Message[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([contactId, instanceId])
  @@index([status, queueId])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT
  OTHER
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  direction      MessageDirection
  type           MessageType      @default(TEXT)
  content        String?
  mediaUrl       String?
  // id da mensagem na Evolution/WhatsApp (key.id)
  externalId     String?          @unique
  status         MessageStatus    @default(PENDING)
  sentById       String?
  timestamp      DateTime         @default(now())
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
}

// ---------- Funil / kanban ----------

model Pipeline {
  id        String   @id @default(uuid())
  name      String   @unique
  stages    Stage[]
  createdAt DateTime @default(now())
}

model Stage {
  id         String   @id @default(uuid())
  pipelineId String
  name       String
  position   Int
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals      Deal[]

  @@unique([pipelineId, position])
}

model Deal {
  id        String   @id @default(uuid())
  title     String
  value     Decimal? @db.Decimal(12, 2)
  stageId   String
  contactId String
  position  Int      @default(0)
  stage     Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Campanhas ----------

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

model Campaign {
  id            String              @id @default(uuid())
  name          String
  instanceId    String
  message       String
  mediaUrl      String?
  status        CampaignStatus      @default(DRAFT)
  scheduledAt   DateTime?
  // mensagens por minuto (controle de taxa para reduzir risco de ban)
  ratePerMinute Int                 @default(10)
  instance      Instance            @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  recipients    CampaignRecipient[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model CampaignRecipient {
  id         String          @id @default(uuid())
  campaignId String
  contactId  String
  status     RecipientStatus @default(PENDING)
  sentAt     DateTime?
  error      String?
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
}
